<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- TOP: title + show odds -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Daily Draw"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/colorAccent" />

        <Button
            android:id="@+id/btnShowOdds"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Show Odds"
            android:textSize="11sp"
            android:textColor="@color/colorAccent"
            android:backgroundTint="@color/colorCard"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <!-- Odds panel -->
    <LinearLayout
        android:id="@+id/layoutOdds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorCard"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draw Rates"
            android:textColor="@color/colorText"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <View android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginTop="2dp" android:layout_marginRight="8dp"
                android:background="@color/rarityCommon" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Common"
                android:textColor="@color/rarityCommon" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="IDs #001–#100  ·  74.5%"
                android:textColor="@color/colorTextSecondary" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <View android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginTop="2dp" android:layout_marginRight="8dp"
                android:background="@color/rarityRare" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Rare"
                android:textColor="@color/rarityRare" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="IDs #101–#130  ·  20%"
                android:textColor="@color/colorTextSecondary" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <View android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginTop="2dp" android:layout_marginRight="8dp"
                android:background="@color/rarityMythical" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Epic"
                android:textColor="@color/rarityMythical" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lapras, Ditto, Porygon, Birds  ·  5%"
                android:textColor="@color/colorTextSecondary" android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <View android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginTop="2dp" android:layout_marginRight="8dp"
                android:background="@color/rarityLegendary" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Legendary"
                android:textColor="@color/rarityLegendary" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Snorlax, Dragonite, Mewtwo, Mew  ·  0.5%"
                android:textColor="@color/colorTextSecondary" android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Gen Unlock Progress -->
    <LinearLayout
        android:id="@+id/layoutGenProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorCard"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Drawing from"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvGenDrawing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Next gen progress (hidden when all gens unlocked) -->
        <LinearLayout
            android:id="@+id/layoutNextGenProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvNextGenLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/colorText"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvGenUnlockProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/pbGenUnlock"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progressTint="@color/colorAccent"
                android:progressBackgroundTint="@color/colorBackground"
                android:max="10" />

        </LinearLayout>

        <!-- Shown when all gens unlocked -->
        <TextView
            android:id="@+id/tvAllGensUnlocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#10003; All Gens Unlocked!"
            android:textColor="@color/rarityLegendary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Spacer: pushes button group to center when no results -->
    <View
        android:id="@+id/spacerTop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- SINGLE CARD MODE: reveal one at a time -->
    <LinearLayout
        android:id="@+id/layoutSingleCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBarSingle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCardProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSingle"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivSinglePokemon"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tvSingleId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvSingleName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorText"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvSingleType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvSingleRarity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnNextCard"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Next →"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- GRID MODE: all at once -->
    <ScrollView
        android:id="@+id/scrollResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDrawResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorText"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDrawResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- Draw info + button -->
    <TextView
        android:id="@+id/tvDrawsRemaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/colorText"
        android:textSize="15sp"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp" />

    <TextView
        android:id="@+id/tvResetTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingBottom="6dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp" />

    <Button
        android:id="@+id/btnDraw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/draw_button"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/colorPrimary"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="4dp" />

    <!-- Auto draw toggle -->
    <LinearLayout
        android:id="@+id/rowAutoDrawInline"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:paddingRight="16dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Draw"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp"
            android:layout_marginRight="8dp" />

        <Switch
            android:id="@+id/switchAutoDrawInline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <View
        android:id="@+id/spacerBottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
